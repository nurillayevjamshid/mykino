{
  "version": 2,
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/static/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/admin",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/beta",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/beta/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ],
  "builds": [
    { "src": "api/movies.js", "use": "@vercel/node" },
    { "src": "api/movie-update.js", "use": "@vercel/node" },
    { "src": "api/movie-reaction.js", "use": "@vercel/node" },
    { "src": "api/music.js", "use": "@vercel/node" },
    { "src": "api/categories.js", "use": "@vercel/node" },
    { "src": "api/settings.js", "use": "@vercel/node" },
    { "src": "api/users.js", "use": "@vercel/node" },
    { "src": "api/broadcast.js", "use": "@vercel/node" },
    { "src": "api/telegram-webhook.js", "use": "@vercel/node" },
    { "src": "api/drive-stream.js", "use": "@vercel/node" },
    { "src": "api/drive-resolve.js", "use": "@vercel/node" },
    { "src": "api/drive-thumbnail.js", "use": "@vercel/node" },
    { "src": "webapp/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/movies", "dest": "/api/movies.js" },
    { "src": "/api/movie-update", "dest": "/api/movie-update.js" },
    { "src": "/api/movie-reaction", "dest": "/api/movie-reaction.js" },
    { "src": "/s/([^/]+)", "dest": "/api/movies.js?_share=1&movie=$1" },
    { "src": "/api/share", "dest": "/api/movies.js?_share=1" },
    { "src": "/api/series", "dest": "/api/movies.js?_series=1" },
    { "src": "/api/series-update", "dest": "/api/movies.js?_series=1" },
    { "src": "/api/watch-progress", "dest": "/api/users.js?_watch=1" },
    { "src": "/api/music", "dest": "/api/music.js" },
    { "src": "/api/categories", "dest": "/api/categories.js" },
    { "src": "/api/upload-image", "dest": "/api/upload-image.js" },
    { "src": "/api/settings", "dest": "/api/settings.js" },
    { "src": "/api/users", "dest": "/api/users.js" },
    { "src": "/api/user-photo", "dest": "/api/users.js?_photo=1" },
    { "src": "/api/broadcast", "dest": "/api/broadcast.js" },
    { "src": "/api/telegram-webhook", "dest": "/api/telegram-webhook.js" },
    { "src": "/api/drive-stream/(.*)", "dest": "/api/drive-stream.js?fileId=$1" },
    { "src": "/api/drive-resolve/(.*)", "dest": "/api/drive-resolve.js?fileId=$1" },
    { "src": "/api/drive-thumbnail/(.*)", "dest": "/api/drive-thumbnail.js?fileId=$1" },
    { "src": "/admin", "dest": "/webapp/admin/index.html" },
    { "src": "/admin/", "dest": "/webapp/admin/index.html" },
    { "src": "/admin/(.*)", "dest": "/webapp/admin/$1" },
    { "src": "/beta", "dest": "/webapp/beta/index.html" },
    { "src": "/beta/", "dest": "/webapp/beta/index.html" },
    { "src": "/beta/(.*)", "dest": "/webapp/beta/$1" },
    { "src": "/static/(.*)", "dest": "/webapp/$1" },
    { "src": "/", "dest": "/webapp/index.html" }
  ]
}
