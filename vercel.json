{
  "version": 2,
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ],
  "builds": [
    {
      "src": "api/movies.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/youtube/movies.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/video-url.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/video-stream.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/stream.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/drive-stream.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/drive-thumbnail.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/movie-update.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/header-section.js",
      "use": "@vercel/node"
    },
    {
      "src": "webapp/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/movies",
      "dest": "/api/movies.js"
    },
    {
      "src": "/api/youtube/movies",
      "dest": "/api/youtube/movies.js"
    },
    {
      "src": "/api/video-url/(.*)",
      "dest": "/api/video-url.js?fileId=$1"
    },
    {
      "src": "/api/video-stream/(.*)",
      "dest": "/api/video-stream.js?fileId=$1"
    },
    {
      "src": "/api/stream/(.*)",
      "dest": "/api/stream.js?fileId=$1"
    },
    {
      "src": "/api/drive-stream/(.*)",
      "dest": "/api/drive-stream.js?fileId=$1"
    },
    {
      "src": "/api/drive-thumbnail/(.*)",
      "dest": "/api/drive-thumbnail.js?fileId=$1"
    },
    {
      "src": "/api/movie-update",
      "dest": "/api/movie-update.js"
    },
    {
      "src": "/api/header-section",
      "dest": "/api/header-section.js"
    },
    {
      "src": "/admin",
      "dest": "/webapp/admin/index.html"
    },
    {
      "src": "/admin/",
      "dest": "/webapp/admin/index.html"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/webapp/admin/$1"
    },
    {
      "src": "/static/(.*)",
      "dest": "/webapp/$1"
    },
    {
      "src": "/",
      "dest": "/webapp/index.html"
    }
  ]
}
